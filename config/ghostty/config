# use cmd+shift+, to reload the config

# Theme: themes/current.conf is a symlink managed by `theme-switcher`
# (fzf picker, also on tmux prefix+t). Optional include (leading ? = no error
# if missing). To disable theming: comment this line out, reload cmd+shift+,
config-file = ?"themes/current.conf"

cursor-style = block
cursor-style-blink = false

macos-titlebar-style = hidden

maximize = true
window-padding-balance = true
window-padding-x = 0
window-padding-y = 0

shell-integration-features = no-cursor,no-sudo,no-title
font-size = 18

# Ghostty intercepts Cmd and sends tmux's 2nd prefix (M-q = ESC q) + the key.

# Windows (tabs)
keybind = cmd+shift+left_bracket=esc:q[
keybind = cmd+shift+right_bracket=esc:q]
keybind = cmd+t=esc:qc
# open the fzf picker and put the chosen dir in a NEW WINDOW (prefix+T -> tmux-windowizer)
keybind = cmd+shift+t=esc:qT
keybind = cmd+w=esc:qx
# kill the whole window (Opt+W; M-w is free in bash and in vi copy-mode)
keybind = alt+w=esc:q&
keybind = cmd+digit_1=esc:q1
keybind = cmd+digit_2=esc:q2
keybind = cmd+digit_3=esc:q3
keybind = cmd+digit_4=esc:q4
keybind = cmd+digit_5=esc:q5
keybind = cmd+digit_6=esc:q6
keybind = cmd+digit_7=esc:q7
keybind = cmd+digit_8=esc:q8
keybind = cmd+digit_9=esc:q9

# Panes
keybind = cmd+d=esc:q%
keybind = cmd+shift+d=esc:q-
keybind = cmd+o=esc:qo

# zoom in both cmd+enter and cmd+z (muscle memory)
keybind = cmd+enter=esc:qz
keybind = cmd+z=esc:qz

# Search scrollback / rename window
keybind = cmd+f=esc:qF
keybind = cmd+r=esc:q,

# Jump to the window/session that alerted (something finished, e.g. Claude).
# Sends prefix+B (not U) because TPM uses prefix+U for plugin updates.
keybind = cmd+u=esc:qB

# Sessions
keybind = cmd+n=esc:qN
keybind = cmd+shift+n=esc:qM
keybind = cmd+s=esc:qs
keybind = cmd+shift+w=esc:qX
keybind = cmd+shift+r=esc:q$
keybind = cmd+shift+up=esc:q(
keybind = cmd+shift+down=esc:q)

# Toggle previous session / last window
keybind = cmd+j=esc:qj
keybind = cmd+l=esc:ql

# New window SSHing into the home Linux box
keybind = cmd+shift+l=esc:qG
