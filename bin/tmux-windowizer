#!/usr/bin/env bash
#
# Like tmux-sessionizer, but opens the picked directory in a NEW WINDOW of the
# current session instead of creating/switching to a whole session.
# Keep the search_dirs list in sync with tmux-sessionizer.

if [[ $# -eq 1 ]]; then
    selected=$1
else
    # path:depth — default depth is 1; bump it for roots with nested repos.
    search_dirs=(
        "$HOME:1"
        "$HOME/work:2"
        "$HOME/Library/CloudStorage/Dropbox:1"
        "$HOME/temp:1"
        "$HOME/temp/investigation:1"
        "$HOME/personal:1"
        "$HOME/projects:1"
        "$HOME/Documents/zotero/ucalp-filosofia:1"
    )

    # ignore hidden files/folders
    selected=$(
        for entry in "${search_dirs[@]}"; do
            find "${entry%:*}" -mindepth 1 -maxdepth "${entry##*:}" -type d -not -path '*/[@.]*' 2>/dev/null
        done | fzf
    )
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)

if [[ -n $TMUX ]]; then
    tmux new-window -c "$selected"
else
    # outside tmux: fall back to creating a session, like tmux-sessionizer
    tmux new-session -s "$selected_name" -c "$selected"
fi
