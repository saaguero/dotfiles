#!/usr/bin/env bash
#
# Like tmux-sessionizer, but opens the picked directory in a NEW WINDOW of the
# current session instead of creating/switching to a whole session.
# Candidate dirs and the fzf toggles are shared via tmux-project-dirs.

if [[ $# -eq 1 ]]; then
    selected=$1
    key=""
else
    # candidate dirs come from the shared lister; Enter just opens the picked dir.
    # ctrl-g toggles "only dirs with a CLAUDE.md"; ctrl-s toggles "study" dirs
    # (zotero materials + Obsidian vault). Neither runs Claude — that's `ccd`.
    # ctrl-o accepts the selection AND opens it with the `ide` layout
    # (vim + agent + terminal, see ~/.local/bin/ide).
    lister="$(dirname "$0")/tmux-project-dirs"
    out=$("$lister" | fzf \
        --expect 'ctrl-o' \
        --prompt 'all> ' \
        --header 'ctrl-g: only CLAUDE.md   ctrl-s: study   ctrl-o: open as IDE' \
        --bind "ctrl-g:transform:[ \"\$FZF_PROMPT\" = 'claude> ' ] && echo 'change-prompt(all> )+reload($lister)' || echo 'change-prompt(claude> )+reload($lister --claude)'" \
        --bind "ctrl-s:transform:[ \"\$FZF_PROMPT\" = 'study> ' ] && echo 'change-prompt(all> )+reload($lister)' || echo 'change-prompt(study> )+reload($lister --study)'")
    key=$(head -n1 <<< "$out")
    selected=$(sed -n '2p' <<< "$out")
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr ' .:' '___')

if [[ -n $TMUX ]]; then
    if [[ $key == "ctrl-o" ]]; then
        tmux new-window -c "$selected" "$HOME/.local/bin/ide"
    else
        tmux new-window -c "$selected"
    fi
else
    # outside tmux: fall back to creating a session, like tmux-sessionizer
    if [[ $key == "ctrl-o" ]]; then
        tmux new-session -ds "$selected_name" -c "$selected" "$HOME/.local/bin/ide"
        exec tmux attach -t "=$selected_name"
    fi
    tmux new-session -s "$selected_name" -c "$selected"
fi
