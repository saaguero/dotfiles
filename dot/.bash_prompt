#!/bin/bash

# export TERM=screen-256color

# Hardcoded escapes instead of tput forks (saves ~50ms per shell startup).
# Values captured verbatim from tput with TERM=screen-256color:
MAGENTA=$'\e[91m'        # tput setaf 9
ORANGE=$'\e[38;5;172m'   # tput setaf 172
YELLOW=$'\e[38;5;193m'   # tput setaf 193
GREEN=$'\e[38;5;190m'    # tput setaf 190
PURPLE=$'\e[38;5;141m'   # tput setaf 141
WHITE=$'\e[38;5;243m'    # tput setaf 243
BOLD=$'\e[1m'            # tput bold
RESET=$'\e[m\017'        # tput sgr0

upsearch () {
  slashes=${PWD//[^\/]/}
  directory="$PWD"
  for (( n=${#slashes}; n>0; --n ))
  do
    test -e "$directory/$1" && echo "$directory/$1" && return 0
    directory="$directory/.."
  done

  return 1
}

parse_git_branch() {
    git branch --no-color 2> /dev/null | sed -e '/^[^*]/d' -e "s/* \(.*\)/\1/"
}

# Adapted from https://gist.github.com/brettstimmerman/382508
parse_svn_branch() {
    if [[ $(upsearch .svn ) && $(svn info 2>/dev/null) ]]; then
        local chunk url=$(svn info | awk '/^URL: .*/{print $2}')

        echo $url | grep -q "/trunk\b"
        if [ $? -eq 0 ] ; then
            echo trunk
            return
        else
            chunk=$(echo $url | grep -o "/releases.*")
            if [ "$chunk" == "" ] ; then
                chunk=$(echo $url | grep -o "/branches.*")
                if [ "$chunk" == "" ] ; then
                    chunk=$(echo $url | grep -o "/tags.*")
                fi
            fi
        fi

        echo $chunk | awk -F/ '{print $3}'
    fi
}

branch_info="\[$BOLD\]\[$WHITE\]\$([[ -n \$(git branch 2> /dev/null) || \$(upsearch .svn) ]] && echo \" -> \")\[$RESET\]\[$PURPLE\]\$(parse_git_branch)\$(parse_svn_branch)"

# The last line's colors must come AFTER its \n: readline (bash 5.3+) repaints
# the final prompt line on its own, and codes placed before the newline belong
# to the previous line — the repaint dropped them (white λ instead of gray).
export PS1="\n\[$YELLOW\]\u@\h: \[$GREEN\]\w$branch_info\n\[$WHITE\]\[$BOLD\] λ \[$RESET\]"

export PS2="\[$ORANGE\]→ \[$RESET\]"

