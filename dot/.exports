#!/bin/bash
export DOTFILES=$HOME/dotfiles
export OBSIDIAN_VAULT=$HOME/Documents/vault
export PERSONAL_DIR=$HOME/personal
export DOTVIM_DIR=$HOME/dotvim

# Make vim the default editor
if hash vim &>/dev/null; then
    export EDITOR='vim'
elif hash gvim &>/dev/null; then
    export EDITOR='gvim -v'
elif hash mvim &>/dev/null; then
    export EDITOR='mvim -v'
fi

# Unlimited bash history
export HISTFILE="$HOME/.bash_history"
export HISTSIZE=100000000
export HISTFILESIZE=$HISTSIZE
export HISTCONTROL=ignoredups

# theoretically prevents macOS from managing your bash history sessions
export SHELL_SESSION_HISTORY=0

# Ctrl+D must be pressed twice to exit bash
export IGNOREEOF=1

# Prefer US English and use UTF-8
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# Highlight section titles in manual pages
export LESS_TERMCAP_md="$ORANGE"

# Don’t clear the screen after quitting a manual page
export MANPAGER="less -X"

# Always enable colored `grep` output
if [ "$(uname)" == "Darwin" ]; then
    export GREP_OPTIONS="--color=auto"
fi

# Neovim exports
if hash nvim &>/dev/null; then
    export NVIM_TUI_ENABLE_CURSOR_SHAPE=1
fi

export FZF_DEFAULT_OPTS='--no-height --no-reverse'
export FZF_CTRL_R_OPTS="--no-sort --exact --preview 'echo {}' --preview-window down:3:hidden:wrap --bind '?:toggle-preview'"
export FZF_CTRL_T_OPTS="--preview '(highlight -O ansi -l {} 2> /dev/null || cat {} || tree -C {}) 2> /dev/null | head -200'"
# fzf: disable ALT-C (I usually press that by accident)
export FZF_ALT_C_COMMAND=""

# Other exports
export WORKON_HOME=$HOME/virtualenvs
export PATH=$PATH:$HOME/.local/bin/

if hash /opt/homebrew/bin/brew &>/dev/null; then
    export PATH="/opt/homebrew/bin:$PATH"
    export PATH="/opt/homebrew/sbin:$PATH"

    # use gnu coreutils instead of the default macOS
    # (hardcoded: `brew --prefix <formula>` is always /opt/homebrew/opt/<formula>,
    # and each call forks brew, ~30ms per call at every shell startup)
    export PATH="/opt/homebrew/opt/coreutils/libexec/gnubin:$PATH"
    export PATH="/opt/homebrew/opt/findutils/libexec/gnubin:$PATH"
fi

# REVIEW_BASE is use in git aliases
export REVIEW_BASE=master

if [ -d "$ASDF_DATA_DIR" ] || [ -d "$HOME/.asdf" ]; then
    export PATH="${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
fi

# virtualenvwrapper: lazy-loaded (the real source forks a Python, ~90ms at
# every shell startup). The first use of any of its commands loads the real
# thing and re-runs that command transparently.
if hash virtualenvwrapper.sh &>/dev/null; then
    _venvwrap_cmds="workon mkvirtualenv rmvirtualenv lsvirtualenv cdvirtualenv cdsitepackages mktmpenv"
    for _cmd in $_venvwrap_cmds; do
        eval "$_cmd() { unset -f $_venvwrap_cmds; source virtualenvwrapper.sh; $_cmd \"\$@\"; }"
    done
    unset _cmd _venvwrap_cmds
fi

# PERF trick for python virtualenv
# workon/rmvirtualenv env-name completion WITHOUT loading virtualenvwrapper
# (which stays lazy-loaded above): just lists $WORKON_HOME dirs that contain
# bin/activate. Zero forks, works from the first prompt. Once the real
# virtualenvwrapper loads (first venv command), its completion takes over.
_lazy_virtualenvs_complete() {
	local d envs=()
	for d in "${WORKON_HOME:-$HOME/.virtualenvs}"/*/; do
		[ -e "${d}bin/activate" ] && { d=${d%/}; envs+=("${d##*/}"); }
	done
	COMPREPLY=($(compgen -W "${envs[*]}" -- "${COMP_WORDS[COMP_CWORD]}"))
}
complete -F _lazy_virtualenvs_complete workon rmvirtualenv cdvirtualenv cdsitepackages

# try (saaguero/try fork): unified view over personal + work tries.
export TRY_PATHS="$HOME/tries:$HOME/work/tries"
