#!/usr/bin/env bash
# External repos are independent clones, not git submodules (simpler to maintain).

DOTVIM_DIR="${DOTVIM_DIR:-$HOME/dotvim}"

if [ -d "$DOTVIM_DIR/.git" ]; then
    echo "Updating dotvim at $DOTVIM_DIR"
    # --ff-only never merges or rebases: if the local clone has diverged
    # (e.g. work in progress), it fails loudly instead of touching anything
    git -C "$DOTVIM_DIR" pull --ff-only || echo "WARN: could not fast-forward $DOTVIM_DIR (local changes?), update it manually."
else
    echo "Cloning dotvim into $DOTVIM_DIR"
    git clone https://github.com/saaguero/dotvim.git "$DOTVIM_DIR"
fi

# The personal repo is private: cloning it is a deliberate manual act (not every
# machine should have it). But if it IS here, this machine was opted in, so keep
# it updated. GIT_TERMINAL_PROMPT=0 avoids hanging on hosts without credentials.
PERSONAL_DIR="${PERSONAL_DIR:-$HOME/personal}"
if [ -d "$PERSONAL_DIR/.git" ]; then
    echo "Updating personal repo at $PERSONAL_DIR"
    GIT_TERMINAL_PROMPT=0 git -C "$PERSONAL_DIR" pull --ff-only || echo "WARN: could not fast-forward $PERSONAL_DIR (no credentials or local changes?), update it manually."
else
    echo "NOTE: personal repo not found at $PERSONAL_DIR (clone it manually if you need it)"
fi
